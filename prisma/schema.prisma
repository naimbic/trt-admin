generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String   @unique
  password       String?
  image          String?
  authority      String[] @default(["user"])
  emailVerified  DateTime?

  // Profile fields
  firstName      String?
  lastName       String?
  phone          String?
  dialCode       String?
  country        String?
  address        String?
  city           String?
  postcode       String?
  birthday       String?
  role           String?  @default("user")
  status         String?  @default("active")
  lastOnline     Int?
  title          String?

  // Notification settings
  notifDesktop          Boolean  @default(true)
  notifUnreadBadge      Boolean  @default(false)
  notifEmail            String[] @default([])
  notifAbout            String?  @default("mentionsOnly")

  // Billing / subscription
  currentPlan           String?  @default("Business board basic")
  planStatus            String?  @default("active")
  billingCycle          String?  @default("monthly")
  nextPaymentDate       Int?
  planAmount            Float?   @default(59.9)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  activityLogs   ActivityLog[]
  notifications  Notification[]
  paymentMethods UserPaymentMethod[]
  transactions   Transaction[]
  integrations   UserIntegration[]

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}


// ==================== USER PAYMENT METHODS ====================

model UserPaymentMethod {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  userId         String  @db.ObjectId
  cardHolderName String
  cardType       String  // VISA, MASTER
  last4Number    String
  expMonth       String
  expYear        String
  primary        Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_payment_methods")
}

// ==================== USER TRANSACTIONS ====================

model Transaction {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  item   String
  status String @default("pending") // pending, paid, failed
  amount Float
  date   Int    // unix timestamp

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ==================== USER INTEGRATIONS ====================

model UserIntegration {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  userId String  @db.ObjectId
  name   String
  desc   String?
  img    String?
  type   String? // Cloud storage, Notifications and events, etc.
  active Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("user_integrations")
}

// ==================== CUSTOMERS ====================

model Customer {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName      String
  lastName       String
  email          String   @unique
  phone          String?
  image          String?
  status         String   @default("active") // active, blocked
  totalSpending  Float    @default(0)

  // Personal info
  dialCode       String?
  location       String?
  address        String?
  city           String?
  country        String?
  postcode       String?
  birthday       DateTime?
  gender         String?
  facebook       String?
  twitter        String?
  pinterest      String?
  linkedIn       String?
  password       String?

  // Delivery address
  deliveryAddress  String?
  deliveryCity     String?
  deliveryCountry  String?
  deliveryPostcode String?

  orders         Order[]
  paymentMethods PaymentMethod[]
  subscriptions  Subscription[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("customers")
}

model PaymentMethod {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  customerId  String  @db.ObjectId
  cardType    String
  last4Number String
  expMonth    String
  expYear     String
  primary     Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model Subscription {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  customerId String  @db.ObjectId
  plan       String
  status     String  @default("active")
  billing    String
  amount     Float

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ==================== PRODUCTS ====================

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  sku         String   @unique
  price       Float
  stock       Int      @default(0)
  status      String   @default("published") // published, draft, inactive
  category    String?
  brand       String?
  taxRate     Float    @default(0)
  images      String[]
  tags        String[]

  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

// ==================== ORDERS ====================

model Order {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId      String   @db.ObjectId
  status          Int      @default(0) // 0=pending, 1=paid, 2=shipped, 3=delivered
  paymentMethod   String?
  paymentId       String?
  totalAmount     Float
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  shippingZip     String?
  note            String?

  customer        Customer    @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  timeline        OrderTimeline[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String @db.ObjectId
  productId String @db.ObjectId
  name      String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderTimeline {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId String   @db.ObjectId
  action  String
  date    DateTime @default(now())
  note    String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_timeline")
}


// ==================== PROJECTS ====================

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  category    String?
  status      String   @default("in-progress") // in-progress, completed, on-hold
  progress    Int      @default(0)
  startDate   DateTime?
  dueDate     DateTime?
  memberIds   String[] @db.ObjectId

  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String?  @db.ObjectId
  title       String
  description String?
  status      String   @default("todo") // todo, in-progress, review, done
  priority    String   @default("medium") // low, medium, high, critical
  assigneeId  String?
  dueDate     DateTime?
  tags        String[]

  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  comments    TaskComment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

model TaskComment {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  taskId  String   @db.ObjectId
  userId  String
  content String
  date    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

// ==================== ACTIVITY & LOGS ====================

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String
  entity    String?  // customer, order, product, project
  entityId  String?
  details   String?
  date      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      String   @default("info") // info, warning, success, error
  link      String?  // URL path to navigate to when clicked
  read      Boolean  @default(false)
  date      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ==================== CHANGELOG ====================

model Changelog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  version    String?
  message    String
  author     String?
  commitHash String?
  type       String   @default("update") // feature, fix, update, breaking
  project    String   @default("backend") // backend, frontend
  files      String[] @default([])
  date       DateTime @default(now())

  @@index([project])
  @@map("changelog")
}

// ==================== HELP CENTER ====================

model Article {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  content    String
  category   String
  slug       String   @unique
  published  Boolean  @default(false)
  viewCount  Int      @default(0)
  authors    String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("articles")
}

// ==================== FILES ====================

model File {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  fileType  String
  size      Int
  url       String
  folder    String?
  uploadedBy String?

  createdAt DateTime @default(now())

  @@map("files")
}

// ==================== WEBSITE INTEGRATION (trtmaroc.com) ====================

// Page interactions (views, likes, shares)
model PageStat {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  slug     String @unique
  views    Int    @default(0)
  likes    Int    @default(0)
  shares   Int    @default(0)
  aiClicks Json?

  @@map("page_stats")
}

// Page interaction events (timeline for analytics chart)
model PageEvent {
  id   String   @id @default(auto()) @map("_id") @db.ObjectId
  slug String
  type String   // view, like, share
  date DateTime @default(now())

  @@index([date])
  @@index([slug])
  @@map("page_events")
}

// Indexing push history
model IndexingLog {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  slug   String
  url    String
  action String   @default("index") // index, remove, recheck
  status String   @default("pending") // pending, success, failed
  method String?  // indexing-api, google-ping
  error  String?
  date   DateTime @default(now())

  @@index([slug])
  @@map("indexing_logs")
}

// Comments (per-slug, supports nesting via parentId)
model Comment {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  slug     String
  name     String
  text     String
  parentId String?  // for nested replies
  likes    Int      @default(0)
  date     DateTime @default(now())

  @@index([slug])
  @@map("comments")
}

// Form submissions (contact, audit, newsletter, lead, candidature)
model Submission {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  form           String?  // contact, audit-gratuit, audit-seo, audit-ads, audit-web, audit-social, audit-aeo, audit-analytics, newsletter, candidature, lead
  name           String?
  email          String?
  phone          String?
  company        String?
  website        String?
  needs          String?
  budget         String?
  budgetMin      String?
  budgetMax      String?
  deadline       String?
  deadlineMonths String?
  message        String?
  read           Boolean  @default(false)
  date           DateTime @default(now())

  @@index([form])
  @@index([date])
  @@map("submissions")
}

// 404 error logs (aggregated by path)
model ErrorLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  path       String   @unique
  hitCount   Int      @default(1)
  redirectId String?
  referrer   String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hitCount])
  @@map("error_logs")
}

// URL redirects (managed by admin, consumed by frontend at build + runtime)
model Redirect {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  from      String   @unique
  to        String
  type      Int      @default(301)
  hits      Int      @default(0)
  active    Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("redirects")
}

// ==================== CALENDAR ====================

model CalendarEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  start       DateTime
  end         DateTime?
  allDay      Boolean  @default(false)
  color       String?
  description String?
  createdBy   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("calendar_events")
}

// ==================== MAIL ====================

model MailThread {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String          // sender display name
  from      String          // sender email
  avatar    String?
  title     String          // subject line
  label     String?         // work, private, important
  group     String   @default("inbox") // inbox, sentItem, draft, starred, deleted
  flagged   Boolean  @default(false)
  starred   Boolean  @default(false)
  to        String[]        // recipient emails
  ownerId   String          // userId who owns this thread

  messages  MailThreadMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([group])
  @@map("mail_threads")
}

model MailThreadMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  threadId  String   @db.ObjectId
  name      String          // sender display name
  from      String          // sender email
  avatar    String?
  content   String          // HTML body
  to        String[]        // recipients
  date      String          // display date string
  attachments Json[]        // [{file, size, type}]

  thread    MailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([threadId])
  @@map("mail_thread_messages")
}

// ==================== CHAT ====================

model ChatConversation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String?  // group name, null for 1:1
  avatar      String?  // group avatar
  chatType    String   @default("personal") // personal, groups
  participantIds String[]
  lastMessage String?
  lastMessageTime DateTime?

  messages    ChatMessage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId
  senderId       String
  senderName     String?
  senderAvatar   String?
  content        String
  type           String   @default("regular") // regular, image, file
  attachments    Json[]   // [{type, mediaUrl}]

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  date           DateTime @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ==================== INVOICING ====================

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  number        String   @unique // FA-042/09/2025
  customerId    String?  @db.ObjectId
  status        String   @default("draft") // draft, sent, paid, overdue, cancelled
  type          String   @default("invoice") // invoice, devis (quote)
  subtotal      Float    @default(0)
  taxRate       Float    @default(20)
  taxAmount     Float    @default(0)
  total         Float    @default(0)
  currency      String   @default("MAD")
  notes         String?
  dueDate       DateTime?
  paidDate      DateTime?

  // Payment info
  paymentMethod String?  // cash, bank_transfer, check, card, other
  paymentAmount Float?
  paymentDate   DateTime?

  // Recurring invoice
  recurring         Boolean  @default(false)
  recurringPeriod   String?  // monthly, yearly
  recurringCycles   Int?     // 1-12 or 0 for infinite
  recurringNext     DateTime?

  items         InvoiceItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId   String @db.ObjectId
  description String
  quantity    Int    @default(1)
  unit        String @default("Unité")
  unitPrice   Float
  total       Float

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ==================== ROLES & PERMISSIONS ====================

model Role {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  roleId        String   @unique // admin, supervisor, support, user, auditor, guest
  name          String
  description   String?
  accessRight   Json     // { users: ['read','write'], products: ['read'], ... }
  order         Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("roles")
}

// ==================== PRICING PLANS ====================

model PricingPlan {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  planId        String   @unique // basic, standard, pro
  name          String
  description   String?
  monthlyPrice  Float
  annualPrice   Float
  features      String[] // feature IDs
  recommended   Boolean  @default(false)
  order         Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_plans")
}

// ==================== HR / EMPLOYEES ====================

model Employee {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  email       String   @unique
  phone       String?
  position    String?
  department  String?
  status      String   @default("active") // active, on-leave, terminated
  hireDate    DateTime?
  salary      Float?
  image       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employees")
}
